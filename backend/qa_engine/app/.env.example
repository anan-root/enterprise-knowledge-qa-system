# LLM service
API_KEY=your_openai_compatible_api_key
BASE_URL=https://your-llm-endpoint/v1
CLS_MODEL=your_classification_model
LLM_MODEL=your_answer_model
SQL_MODEL=your_sql_model
RAGAS_LLM=your_eval_model
MAX_CONCURRENT=5

# MySQL structured data
host=127.0.0.1
user=root
password=your_mysql_password
db=your_database
include_tables=["政府招标信息","市场产品信息"]

# Milvus / embedding / rerank
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
BGE_M3_URL=http://127.0.0.1:8000
BGE_RERANKER_URL=http://127.0.0.1:8001
BM25_DIR=backend/qa_engine/data_processing
INDEX_PATH=["中华人民共和国招标投标法律法规全书_bm25.pkl","招标投标法律解读与风险防范实务_bm25.pkl"]
VECTOR_DATA=backend/qa_engine/data_processing/vector_data
SENTENCE_MODEL=BAAI/bge-large-zh-v1.5

# Redis cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# External data providers
SERPER_API_KEY=your_serper_api_key
JY_AppID=your_jianyu_app_id
JY_SecretKey=your_jianyu_secret_key
qcc_api_key=your_qcc_api_key
